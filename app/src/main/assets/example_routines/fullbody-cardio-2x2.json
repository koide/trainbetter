{
  "id": "fullbody-cardio-2x2",
  "name": "Full-body + Cardio (2+2)",
  "description": "Two full-body strength days plus two cardio days each week. Default Mon (strength) / Tue (cardio) / Thu (strength) / Fri (cardio). A balanced template for trainees who don't want strength to crowd out conditioning.",
  "author": "DiTrain bundled templates",
  "schemaVersion": 1,
  "loopMode": "REPEAT",
  "defaultWeeklyPattern": [0, 1, 3, 4],
  "weeks": [
    {
      "label": "Week 1",
      "sessions": [
        {
          "id": "hc-s-a",
          "name": "Strength A",
          "blocks": [
            { "exerciseId": "barbell-back-squat", "sets": [
              {"type":"straight","reps":{"type":"fixed","reps":5},"load":{"type":"pct_1rm","pct":0.80},"rest":180},
              {"type":"straight","reps":{"type":"fixed","reps":5},"load":{"type":"pct_1rm","pct":0.80},"rest":180},
              {"type":"straight","reps":{"type":"fixed","reps":5},"load":{"type":"pct_1rm","pct":0.80},"rest":180}
            ]},
            { "exerciseId": "barbell-bench-press", "sets": [
              {"type":"straight","reps":{"type":"fixed","reps":5},"load":{"type":"pct_1rm","pct":0.80},"rest":150},
              {"type":"straight","reps":{"type":"fixed","reps":5},"load":{"type":"pct_1rm","pct":0.80},"rest":150},
              {"type":"straight","reps":{"type":"fixed","reps":5},"load":{"type":"pct_1rm","pct":0.80},"rest":150}
            ]},
            { "exerciseId": "barbell-row", "sets": [
              {"type":"straight","reps":{"type":"range","min":8,"max":10},"load":{"type":"open"},"rpeTarget":8.0,"rest":120},
              {"type":"straight","reps":{"type":"range","min":8,"max":10},"load":{"type":"open"},"rpeTarget":8.0,"rest":120},
              {"type":"straight","reps":{"type":"range","min":8,"max":10},"load":{"type":"open"},"rpeTarget":8.0,"rest":120}
            ]},
            { "exerciseId": "plank", "sets": [
              {"type":"straight","reps":{"type":"fixed","reps":1},"load":{"type":"open"},"rest":90,"notes":"hold 30-60 sec"},
              {"type":"straight","reps":{"type":"fixed","reps":1},"load":{"type":"open"},"rest":90,"notes":"hold 30-60 sec"},
              {"type":"straight","reps":{"type":"fixed","reps":1},"load":{"type":"open"},"rest":90,"notes":"hold 30-60 sec"}
            ]}
          ],
          "cardioBlocks": []
        },
        {
          "id": "hc-c-a",
          "name": "Cardio A (steady run)",
          "blocks": [],
          "cardioBlocks": [
            { "activityKind": "RUNNING", "description": "Steady-state easy pace", "targetDurationMin": 30, "targetAvgBpm": 140 }
          ]
        },
        {
          "id": "hc-s-b",
          "name": "Strength B",
          "blocks": [
            { "exerciseId": "barbell-deadlift", "sets": [
              {"type":"straight","reps":{"type":"fixed","reps":3},"load":{"type":"pct_1rm","pct":0.85},"rest":240},
              {"type":"straight","reps":{"type":"fixed","reps":3},"load":{"type":"pct_1rm","pct":0.85},"rest":240},
              {"type":"straight","reps":{"type":"fixed","reps":3},"load":{"type":"pct_1rm","pct":0.85},"rest":240}
            ]},
            { "exerciseId": "barbell-overhead-press", "sets": [
              {"type":"straight","reps":{"type":"fixed","reps":5},"load":{"type":"pct_1rm","pct":0.75},"rest":150},
              {"type":"straight","reps":{"type":"fixed","reps":5},"load":{"type":"pct_1rm","pct":0.75},"rest":150},
              {"type":"straight","reps":{"type":"fixed","reps":5},"load":{"type":"pct_1rm","pct":0.75},"rest":150}
            ]},
            { "exerciseId": "pull-up", "sets": [
              {"type":"straight","reps":{"type":"amrap"},"load":{"type":"open"},"rest":120},
              {"type":"straight","reps":{"type":"amrap"},"load":{"type":"open"},"rest":120},
              {"type":"straight","reps":{"type":"amrap"},"load":{"type":"open"},"rest":120}
            ]},
            { "exerciseId": "lateral-raise", "sets": [
              {"type":"straight","reps":{"type":"range","min":12,"max":15},"load":{"type":"open"},"rest":60},
              {"type":"straight","reps":{"type":"range","min":12,"max":15},"load":{"type":"open"},"rest":60},
              {"type":"straight","reps":{"type":"range","min":12,"max":15},"load":{"type":"open"},"rest":60}
            ]}
          ],
          "cardioBlocks": []
        },
        {
          "id": "hc-c-b",
          "name": "Cardio B (cycling)",
          "blocks": [],
          "cardioBlocks": [
            { "activityKind": "CYCLING", "description": "Moderate cycling, mix of pace", "targetDurationMin": 40, "targetAvgBpm": 145 }
          ]
        }
      ]
    }
  ]
}
